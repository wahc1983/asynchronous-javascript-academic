---
---
<div class="workers-visualizer" id="workers-visualizer">
  <div class="lanes-container">

    <!-- Main Thread -->
    <div class="lane lane-main" id="lane-main">
      <div class="lane-header">
        <span class="lane-label">Main Thread</span>
        <span
          id="status-main"
          class="lane-status status-idle"
          data-status="idle"
          aria-label="Estado del hilo principal"
        >idle</span>
      </div>
      <div class="lane-blocks" id="blocks-main"></div>
    </div>

    <!-- Message Channel -->
    <div class="message-channel" id="message-channel" aria-label="Canal de mensajes entre hilos">
      <div class="channel-label">postMessage</div>
      <div class="channel-arrows">
        <span class="arrow arrow-right" aria-hidden="true">→</span>
        <span class="arrow arrow-left" aria-hidden="true">←</span>
      </div>
    </div>

    <!-- Worker Thread -->
    <div class="lane lane-worker" id="lane-worker">
      <div class="lane-header">
        <span class="lane-label">Worker Thread</span>
        <span
          id="status-worker"
          class="lane-status status-idle"
          data-status="idle"
          aria-label="Estado del worker thread"
        >idle</span>
      </div>
      <div class="lane-blocks" id="blocks-worker"></div>
    </div>

  </div>
</div>

<script>
  import { WorkersVisualizerEngine } from '../scripts/workersVisualizer';

  const visualizer = document.getElementById('workers-visualizer');
  if (visualizer) {
    const engine = new WorkersVisualizerEngine();
    (window as any).workersVisualizerEngine = engine;
  }
</script>

<style>
  .workers-visualizer {
    width: 100%;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    backdrop-filter: blur(8px);
  }

  /* Layout horizontal de los dos carriles + canal central */
  .lanes-container {
    display: flex;
    flex-direction: row;
    gap: var(--space-4);
    align-items: stretch;
  }

  /* ── Carril base ── */
  .lane {
    flex: 1;
    display: flex;
    flex-direction: column;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    min-height: 300px;
    overflow: hidden;
    transition:
      border-color var(--anim-duration) var(--anim-easing),
      box-shadow var(--anim-duration) var(--anim-easing);
  }

  /* Colores por carril */
  .lane-main {
    border-color: var(--color-main-thread, #38BDF8);
    color: var(--color-main-thread, #38BDF8);
  }

  .lane-main .lane-header {
    background: var(--color-main-thread-bg, #0C2A3F);
    border-bottom-color: var(--color-main-thread, #38BDF8);
  }

  .lane-worker {
    border-color: var(--color-worker-thread, #F472B6);
    color: var(--color-worker-thread, #F472B6);
  }

  .lane-worker .lane-header {
    background: var(--color-worker-thread-bg, #3D0A24);
    border-bottom-color: var(--color-worker-thread, #F472B6);
  }

  /* Highlight de carril */
  .lane.highlighted {
    box-shadow: 0 0 0 3px currentColor, 0 0 20px currentColor;
  }

  @keyframes highlight-pulse {
    0%, 100% { box-shadow: 0 0 0 0 transparent; }
    50%       { box-shadow: 0 0 0 4px currentColor, 0 0 24px currentColor; }
  }

  .lane.highlighted {
    animation: highlight-pulse 600ms ease both;
  }

  /* ── Cabecera del carril ── */
  .lane-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid;
    gap: var(--space-2);
  }

  .lane-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: inherit;
  }

  /* ── Indicador de estado ── */
  .lane-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid currentColor;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background-color 300ms ease, color 300ms ease;
  }

  .status-idle {
    color: var(--color-text-muted);
    border-color: var(--color-text-muted);
    background: transparent;
  }

  .status-working {
    color: #FCD34D;
    border-color: #FCD34D;
    background: rgba(252, 211, 77, 0.1);
  }

  .status-sending {
    color: #34D399;
    border-color: #34D399;
    background: rgba(52, 211, 153, 0.1);
  }

  /* ── Área de bloques ── */
  .lane-blocks {
    flex: 1;
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: stretch;
    overflow: hidden;
    min-width: 0;
  }

  /* ── Bloques de animación ── */
  .anim-block {
    background: var(--color-surface-2);
    border: 1px solid var(--block-color, var(--color-accent));
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text);
    box-shadow: 0 0 6px 0 color-mix(in srgb, var(--block-color, var(--color-accent)) 30%, transparent);
    width: 100%;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    cursor: default;
  }

  /* ── Canal de mensajes ── */
  .message-channel {
    width: 80px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    position: relative;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: rgba(71, 85, 105, 0.1);
    min-height: 300px;
    padding: var(--space-2);
  }

  .channel-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    text-align: center;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  .channel-arrows {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: center;
  }

  .arrow {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  /* ── Bloques de mensaje en tránsito ── */
  .message-block {
    background: var(--color-message-block-bg, #3D2A00);
    border: 1px solid var(--color-message-block, #FCD34D);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-message-block, #FCD34D);
    box-shadow: 0 0 8px 0 color-mix(in srgb, var(--color-message-block, #FCD34D) 40%, transparent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 70px;
    cursor: default;
  }
</style>
