---
import Mascot from '../Mascot.astro';
---
<section class="slide slide-ww07">
  <div class="content">
    <h2 class="title">Resumen: Web Workers y Paralelismo</h2>

    <!-- Diagrama SVG de arquitectura -->
    <div class="diagram-wrapper" aria-label="Diagrama de arquitectura: Main Thread, Worker Thread y Message Channel con postMessage bidireccional">
      <svg class="arch-diagram" viewBox="0 0 720 200" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="ww07-mainGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#0C2A3F"/>
            <stop offset="100%" stop-color="#0a1e2e"/>
          </linearGradient>
          <linearGradient id="ww07-workerGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#3D0A24"/>
            <stop offset="100%" stop-color="#2a0618"/>
          </linearGradient>
          <linearGradient id="ww07-channelGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#38BDF8"/>
            <stop offset="50%" stop-color="#FCD34D"/>
            <stop offset="100%" stop-color="#F472B6"/>
          </linearGradient>
          <marker id="ww07-arrowBlue" markerWidth="7" markerHeight="7" refX="6" refY="3.5" orient="auto">
            <path d="M0,0 L7,3.5 L0,7 Z" fill="#38BDF8"/>
          </marker>
          <marker id="ww07-arrowPink" markerWidth="7" markerHeight="7" refX="6" refY="3.5" orient="auto">
            <path d="M0,0 L7,3.5 L0,7 Z" fill="#F472B6"/>
          </marker>
          <filter id="ww07-glow-blue">
            <feGaussianBlur stdDeviation="3" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="ww07-glow-pink">
            <feGaussianBlur stdDeviation="3" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>

        <!-- Main Thread box -->
        <rect x="10" y="20" width="200" height="160" rx="10" fill="url(#ww07-mainGrad)" stroke="#38BDF8" stroke-width="2"/>
        <text x="110" y="44" text-anchor="middle" fill="#38BDF8" font-size="11" font-weight="700" letter-spacing="1">MAIN THREAD</text>
        <line x1="10" y1="52" x2="210" y2="52" stroke="#38BDF8" stroke-width="1" opacity="0.4"/>

        <!-- Main Thread internals -->
        <rect x="24" y="62" width="172" height="26" rx="5" fill="#1D3461" stroke="#3B82F6" stroke-width="1.5"/>
        <text x="110" y="79" text-anchor="middle" fill="#93C5FD" font-size="9" font-family="monospace">Event Loop ↻</text>

        <rect x="24" y="96" width="172" height="26" rx="5" fill="#1D3461" stroke="#3B82F6" stroke-width="1.5"/>
        <text x="110" y="113" text-anchor="middle" fill="#93C5FD" font-size="9" font-family="monospace">DOM / UI</text>

        <rect x="24" y="130" width="172" height="26" rx="5" fill="#1D3461" stroke="#3B82F6" stroke-width="1.5"/>
        <text x="110" y="147" text-anchor="middle" fill="#93C5FD" font-size="9" font-family="monospace">postMessage( data )</text>

        <!-- Status badge main -->
        <rect x="24" y="162" width="60" height="14" rx="7" fill="#0C2A3F" stroke="#38BDF8" stroke-width="1"/>
        <text x="54" y="173" text-anchor="middle" fill="#38BDF8" font-size="7" font-weight="700">● working</text>

        <!-- Message Channel (center) -->
        <rect x="240" y="60" width="240" height="80" rx="8" fill="#0F172A" stroke="url(#ww07-channelGrad)" stroke-width="2"/>
        <text x="360" y="82" text-anchor="middle" fill="#FCD34D" font-size="10" font-weight="700">MESSAGE CHANNEL</text>
        <line x1="240" y1="90" x2="480" y2="90" stroke="#FCD34D" stroke-width="1" opacity="0.3"/>

        <!-- Arrow: Main → Worker -->
        <path d="M260 105 L460 105" stroke="#38BDF8" stroke-width="2" marker-end="url(#ww07-arrowBlue)" filter="url(#ww07-glow-blue)"/>
        <rect x="300" y="95" width="120" height="16" rx="4" fill="#0C2A3F"/>
        <text x="360" y="107" text-anchor="middle" fill="#7DD3FC" font-size="8" font-family="monospace">postMessage(data) →</text>

        <!-- Arrow: Worker → Main -->
        <path d="M460 125 L260 125" stroke="#F472B6" stroke-width="2" marker-end="url(#ww07-arrowPink)" filter="url(#ww07-glow-pink)"/>
        <rect x="300" y="115" width="120" height="16" rx="4" fill="#3D0A24"/>
        <text x="360" y="127" text-anchor="middle" fill="#FBCFE8" font-size="8" font-family="monospace">← postMessage(result)</text>

        <!-- Structured clone label -->
        <text x="360" y="152" text-anchor="middle" fill="#94A3B8" font-size="8">structured clone (copia, no referencia)</text>

        <!-- Worker Thread box -->
        <rect x="510" y="20" width="200" height="160" rx="10" fill="url(#ww07-workerGrad)" stroke="#F472B6" stroke-width="2"/>
        <text x="610" y="44" text-anchor="middle" fill="#F472B6" font-size="11" font-weight="700" letter-spacing="1">WORKER THREAD</text>
        <line x1="510" y1="52" x2="710" y2="52" stroke="#F472B6" stroke-width="1" opacity="0.4"/>

        <!-- Worker Thread internals -->
        <rect x="524" y="62" width="172" height="26" rx="5" fill="#5a1035" stroke="#F472B6" stroke-width="1.5"/>
        <text x="610" y="79" text-anchor="middle" fill="#FBCFE8" font-size="9" font-family="monospace">onmessage handler</text>

        <rect x="524" y="96" width="172" height="26" rx="5" fill="#5a1035" stroke="#F472B6" stroke-width="1.5"/>
        <text x="610" y="113" text-anchor="middle" fill="#FBCFE8" font-size="9" font-family="monospace">CPU-intensive work</text>

        <rect x="524" y="130" width="172" height="26" rx="5" fill="#5a1035" stroke="#F472B6" stroke-width="1.5"/>
        <text x="610" y="147" text-anchor="middle" fill="#FBCFE8" font-size="9" font-family="monospace">postMessage( result )</text>

        <!-- Status badge worker -->
        <rect x="524" y="162" width="60" height="14" rx="7" fill="#3D0A24" stroke="#F472B6" stroke-width="1"/>
        <text x="554" y="173" text-anchor="middle" fill="#F472B6" font-size="7" font-weight="700">● working</text>

        <!-- No DOM badge -->
        <rect x="620" y="162" width="66" height="14" rx="7" fill="#3D0A24" stroke="#EF4444" stroke-width="1"/>
        <text x="653" y="173" text-anchor="middle" fill="#EF4444" font-size="7" font-weight="700">✕ sin DOM</text>

        <!-- Connecting lines from boxes to channel -->
        <line x1="210" y1="100" x2="240" y2="100" stroke="#38BDF8" stroke-width="1.5" stroke-dasharray="4,3"/>
        <line x1="480" y1="100" x2="510" y2="100" stroke="#F472B6" stroke-width="1.5" stroke-dasharray="4,3"/>
      </svg>
    </div>

    <!-- Bottom grid: tabla + recursos -->
    <div class="bottom-grid">

      <!-- Tabla comparativa -->
      <div class="table-wrapper">
        <h3 class="section-label">⚖️ Event Loop vs Web Workers</h3>
        <table class="compare-table" aria-label="Tabla comparativa entre Event Loop y Web Workers">
          <thead>
            <tr>
              <th scope="col">Dimensión</th>
              <th scope="col" class="th-el">Event Loop</th>
              <th scope="col" class="th-ww">Web Workers</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="dim">Número de hilos</td>
              <td class="val-el">1 (hilo único)</td>
              <td class="val-ww">2+ (paralelo real)</td>
            </tr>
            <tr>
              <td class="dim">Acceso al DOM</td>
              <td class="val-el">✓ Completo</td>
              <td class="val-ww">✕ No permitido</td>
            </tr>
            <tr>
              <td class="dim">Tipo de tareas</td>
              <td class="val-el">I/O, eventos, UI</td>
              <td class="val-ww">CPU intensivo</td>
            </tr>
            <tr>
              <td class="dim">Comunicación</td>
              <td class="val-el">Call Stack directo</td>
              <td class="val-ww">postMessage / message</td>
            </tr>
            <tr>
              <td class="dim">Bloqueo de UI</td>
              <td class="val-el">Posible (sync code)</td>
              <td class="val-ww">Nunca (hilo separado)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Recursos adicionales -->
      <div class="resources">
        <h3 class="section-label">📚 Para profundizar</h3>
        <ul class="resources-list">
          <li>
            <span class="resource-tag">Docs</span>
            <a
              href="https://developer.mozilla.org/es/docs/Web/API/Web_Workers_API"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="MDN Web Docs: Web Workers API (abre en nueva pestaña)"
            >MDN Web Docs: Web Workers API</a>
          </li>
          <li>
            <span class="resource-tag">Guía</span>
            <a
              href="https://developer.mozilla.org/es/docs/Web/API/Web_Workers_API/Using_web_workers"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="MDN: Using Web Workers (abre en nueva pestaña)"
            >MDN: Using Web Workers</a>
          </li>
          <li>
            <span class="resource-tag">Ejemplo</span>
            <a
              href="https://github.com/mdn/dom-examples/tree/main/web-workers/simple-web-worker"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Ejemplo en GitHub: MDN simple web worker (abre en nueva pestaña)"
            >GitHub: MDN simple-web-worker</a>
          </li>
        </ul>

        <div class="closing-message">
          <p class="closing-emoji">🧵</p>
          <p class="closing-text">
            El paralelismo real en JavaScript ya no es magia.
            ¡Mueve el trabajo pesado al worker y mantén la UI siempre fluida!
          </p>
        </div>
      </div>

    </div>

    <!-- Limitaciones y buenas prácticas -->
    <div class="bottom-row">
      <div class="limits-card">
        <h3 class="section-label">⚠️ Limitaciones</h3>
        <ul class="limits-list">
          <li><span class="limit-icon">🚫</span> Sin acceso al DOM, <code>window</code> ni <code>document</code></li>
          <li><span class="limit-icon">💾</span> Cada worker consume memoria (hilo del SO)</li>
          <li><span class="limit-icon">⏱️</span> La comunicación por mensajes introduce latencia</li>
          <li><span class="limit-icon">🌐</span> No disponible en browsers muy antiguos</li>
        </ul>
      </div>

      <div class="practices-card">
        <h3 class="section-label">✅ Buenas prácticas</h3>
        <ul class="practices-list">
          <li>
            <code class="practice-code">worker.terminate()</code>
            <span>Libera el hilo cuando ya no se necesita</span>
          </li>
          <li>
            <code class="practice-code">worker.onerror</code>
            <span>Siempre maneja errores del worker</span>
          </li>
          <li>
            <span class="practice-text">📦 Minimiza el tamaño y frecuencia de los mensajes</span>
          </li>
          <li>
            <span class="practice-text">🪶 Mantén los scripts del worker ligeros</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
  <Mascot message="¡Dos hilos, cero bloqueos! Ahora ya sabes cómo hacer JavaScript verdaderamente paralelo. 🚀" mood="excited" position="bottom-left" />
</section>

<style>
  .slide-ww07 {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    height: 100%;
    overflow-y: auto;
    background: radial-gradient(ellipse at 50% 50%, #1a0a1e 0%, var(--color-bg) 65%);
  }

  .content {
    width: 100%;
    max-width: 920px;
    padding: var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .title {
    font-size: var(--text-3xl);
    font-weight: 800;
    text-align: center;
    background: linear-gradient(135deg, #38BDF8, #F472B6, #10B981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Diagram */
  .diagram-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
  }

  .arch-diagram {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 18px #38BDF811);
  }

  /* Bottom grid */
  .bottom-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-5);
    align-items: start;
  }

  .section-label {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  /* Comparison table */
  .table-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .compare-table thead tr {
    border-bottom: 2px solid var(--color-border);
  }

  .compare-table th {
    padding: var(--space-2) var(--space-3);
    text-align: left;
    font-weight: 700;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .th-el { color: #38BDF8; }
  .th-ww { color: #F472B6; }

  .compare-table tbody tr {
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s ease;
  }

  .compare-table tbody tr:last-child {
    border-bottom: none;
  }

  .compare-table tbody tr:hover {
    background: var(--color-surface-2);
  }

  .compare-table td {
    padding: var(--space-2) var(--space-3);
    line-height: 1.5;
  }

  .dim {
    color: var(--color-text);
    font-weight: 600;
    white-space: nowrap;
  }

  .val-el {
    color: #7DD3FC;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .val-ww {
    color: #FBCFE8;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  /* Resources */
  .resources {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .resources-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .resources-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .resource-tag {
    background: var(--color-surface-2);
    color: var(--color-accent);
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .resources-list a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .resources-list a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Closing message */
  .closing-message {
    background: linear-gradient(135deg, #1a0a1e, #0a1a2e);
    border: 1px solid #F472B6;
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .closing-emoji {
    font-size: 2.5rem;
    line-height: 1;
  }

  .closing-text {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
  }

  /* Limitaciones y buenas prácticas */
  .bottom-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .limits-card,
  .practices-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
  }

  .limits-card { border-left: 4px solid #EF4444; }
  .practices-card { border-left: 4px solid #10B981; }

  .limits-list,
  .practices-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .limits-list li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .limits-list code {
    color: #FCA5A5;
    background: var(--color-surface-2);
    padding: 1px 4px;
    border-radius: 3px;
    font-size: var(--text-xs);
  }

  .limit-icon { flex-shrink: 0; }

  .practices-list li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .practice-code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: #6EE7B7;
    background: var(--color-surface-2);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .practice-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
