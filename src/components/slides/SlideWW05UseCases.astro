---
import Mascot from '../Mascot.astro';
---
<section class="slide slide-ww05">
  <div class="content">
    <h2 class="title">Casos de uso reales</h2>
    <p class="subtitle">¿Cuándo vale la pena usar un Web Worker?</p>

    <div class="cases-grid">

      <!-- Caso 1: Procesamiento de imágenes -->
      <div class="case-card">
        <div class="case-icon-wrap" style="background:#0C2A3F; border-color:#38BDF8;">
          <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="4" y="8" width="40" height="30" rx="4" fill="#1D3461" stroke="#38BDF8" stroke-width="2"/>
            <circle cx="16" cy="20" r="5" fill="#38BDF8" opacity="0.8"/>
            <path d="M4 30 L14 20 L22 28 L30 18 L44 30" stroke="#10B981" stroke-width="2" fill="none" stroke-linejoin="round"/>
            <!-- Filtro / procesamiento -->
            <rect x="28" y="10" width="14" height="14" rx="2" fill="#0C2A3F" stroke="#38BDF8" stroke-width="1.5" opacity="0.9"/>
            <line x1="31" y1="13" x2="39" y2="13" stroke="#38BDF8" stroke-width="1"/>
            <line x1="31" y1="16" x2="39" y2="16" stroke="#38BDF8" stroke-width="1"/>
            <line x1="31" y1="19" x2="36" y2="19" stroke="#38BDF8" stroke-width="1"/>
          </svg>
        </div>
        <div class="case-body">
          <h3 class="case-title">Procesamiento de imágenes / Canvas</h3>
          <p class="case-desc">
            Aplicar filtros, redimensionar, comprimir o analizar píxeles de una imagen
            sin congelar la UI mientras el usuario sigue interactuando.
          </p>
          <div class="case-examples">
            <span class="tag">filtros CSS</span>
            <span class="tag">OCR</span>
            <span class="tag">compresión</span>
            <span class="tag">OffscreenCanvas</span>
          </div>
        </div>
      </div>

      <!-- Caso 2: Cálculos intensivos -->
      <div class="case-card">
        <div class="case-icon-wrap" style="background:#3D0A24; border-color:#F472B6;">
          <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- CPU / chip -->
            <rect x="12" y="12" width="24" height="24" rx="3" fill="#5a1035" stroke="#F472B6" stroke-width="2"/>
            <rect x="17" y="17" width="14" height="14" rx="2" fill="#3D0A24" stroke="#F472B6" stroke-width="1"/>
            <text x="24" y="28" text-anchor="middle" fill="#F472B6" font-size="9" font-weight="700" font-family="monospace">fn()</text>
            <!-- Pines -->
            <line x1="16" y1="8"  x2="16" y2="12" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="24" y1="8"  x2="24" y2="12" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="32" y1="8"  x2="32" y2="12" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="16" y1="36" x2="16" y2="40" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="24" y1="36" x2="24" y2="40" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="32" y1="36" x2="32" y2="40" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="8"  y1="16" x2="12" y2="16" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="8"  y1="24" x2="12" y2="24" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="8"  y1="32" x2="12" y2="32" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="36" y1="16" x2="40" y2="16" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="36" y1="24" x2="40" y2="24" stroke="#F472B6" stroke-width="1.5"/>
            <line x1="36" y1="32" x2="40" y2="32" stroke="#F472B6" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="case-body">
          <h3 class="case-title">Cálculos intensivos</h3>
          <p class="case-desc">
            Algoritmos que requieren mucho tiempo de CPU: números primos, Fibonacci,
            modelos de Machine Learning, simulaciones físicas o criptografía.
          </p>
          <div class="case-examples">
            <span class="tag" style="border-color:#F472B6; color:#F472B6;">fibonacci</span>
            <span class="tag" style="border-color:#F472B6; color:#F472B6;">ML inference</span>
            <span class="tag" style="border-color:#F472B6; color:#F472B6;">criptografía</span>
          </div>
        </div>
      </div>

      <!-- Caso 3: Parsing de datos grandes -->
      <div class="case-card">
        <div class="case-icon-wrap" style="background:#1a2a0a; border-color:#10B981;">
          <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Documento -->
            <rect x="8" y="4" width="28" height="36" rx="3" fill="#064E3B" stroke="#10B981" stroke-width="2"/>
            <path d="M28 4 L36 12 L28 12 Z" fill="#10B981" opacity="0.5"/>
            <line x1="13" y1="18" x2="31" y2="18" stroke="#10B981" stroke-width="1.5"/>
            <line x1="13" y1="23" x2="31" y2="23" stroke="#10B981" stroke-width="1.5"/>
            <line x1="13" y1="28" x2="25" y2="28" stroke="#10B981" stroke-width="1.5"/>
            <!-- Flecha de parse -->
            <path d="M34 28 L42 28" stroke="#10B981" stroke-width="2" marker-end="url(#ww05-arrow-green)"/>
            <rect x="38" y="22" width="8" height="12" rx="2" fill="#064E3B" stroke="#10B981" stroke-width="1.5"/>
            <text x="42" y="31" text-anchor="middle" fill="#6EE7B7" font-size="6" font-weight="700">{}</text>
            <defs>
              <marker id="ww05-arrow-green" markerWidth="6" markerHeight="6" refX="6" refY="3" orient="auto">
                <path d="M0,0 L6,3 L0,6 Z" fill="#10B981"/>
              </marker>
            </defs>
          </svg>
        </div>
        <div class="case-body">
          <h3 class="case-title">Parsing de datos grandes</h3>
          <p class="case-desc">
            Parsear archivos CSV de miles de filas, JSON masivos de una API,
            o procesar logs en tiempo real sin bloquear la interfaz.
          </p>
          <div class="case-examples">
            <span class="tag" style="border-color:#10B981; color:#10B981;">CSV masivo</span>
            <span class="tag" style="border-color:#10B981; color:#10B981;">JSON grande</span>
            <span class="tag" style="border-color:#10B981; color:#10B981;">logs en tiempo real</span>
          </div>
        </div>
      </div>

      <!-- Caso 4: Datos en tiempo real -->
      <div class="case-card">
        <div class="case-icon-wrap" style="background:#1a0a2e; border-color:#A78BFA;">
          <svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Señal / ondas -->
            <circle cx="24" cy="28" r="4" fill="#A78BFA" opacity="0.9"/>
            <path d="M16 28 Q16 18 24 18 Q32 18 32 28" stroke="#A78BFA" stroke-width="2" fill="none" opacity="0.7"/>
            <path d="M10 28 Q10 10 24 10 Q38 10 38 28" stroke="#A78BFA" stroke-width="1.5" fill="none" opacity="0.4"/>
            <!-- Flecha hacia abajo (stream) -->
            <line x1="24" y1="32" x2="24" y2="40" stroke="#A78BFA" stroke-width="2"/>
            <path d="M20 37 L24 42 L28 37" stroke="#A78BFA" stroke-width="1.5" fill="none"/>
          </svg>
        </div>
        <div class="case-body">
          <h3 class="case-title">Datos en tiempo real</h3>
          <p class="case-desc">
            Procesar streams de WebSockets, lecturas de sensores IoT o análisis
            de audio/video en vivo sin interrumpir la UI.
          </p>
          <div class="case-examples">
            <span class="tag" style="border-color:#A78BFA; color:#A78BFA;">WebSockets</span>
            <span class="tag" style="border-color:#A78BFA; color:#A78BFA;">IoT / sensores</span>
            <span class="tag" style="border-color:#A78BFA; color:#A78BFA;">audio/video</span>
          </div>
        </div>
      </div>

    </div>

    <div class="rule-of-thumb">
      <span class="rule-icon">🎯</span>
      <p>
        <strong>Regla general:</strong> si una tarea tarda más de <strong>~16 ms</strong>
        (un frame a 60 fps), considera moverla a un Web Worker para mantener la UI fluida.
      </p>
    </div>
  </div>
  <Mascot message="Imágenes, cálculos, datos... si tarda más de un frame, ¡al worker!" mood="excited" position="top-left" />
</section>

<style>
  .slide-ww05 {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    background: radial-gradient(ellipse at 50% 40%, #0a1a0a 0%, var(--color-bg) 65%);
    overflow-y: auto;
  }

  .content {
    width: 100%;
    max-width: 920px;
    padding: var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .title {
    font-size: var(--text-3xl);
    font-weight: 800;
    text-align: center;
    background: linear-gradient(135deg, var(--color-main-thread, #38BDF8), #10B981, var(--color-worker-thread, #F472B6));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    text-align: center;
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-top: calc(-1 * var(--space-3));
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .case-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color 0.2s ease;
  }

  .case-card:hover {
    border-color: var(--color-accent);
  }

  .case-icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    border: 2px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .case-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .case-title {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
  }

  .case-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .case-examples {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-top: var(--space-1);
  }

  .tag {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 1px 6px;
    white-space: nowrap;
  }

  .rule-of-thumb {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid #FCD34D;
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .rule-icon {
    font-size: var(--text-xl);
    flex-shrink: 0;
  }

  .rule-of-thumb p {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
  }

  .rule-of-thumb strong {
    color: #FCD34D;
  }
</style>
