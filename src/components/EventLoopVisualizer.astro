---
---
<div class="visualizer" id="event-loop-visualizer">
  <div class="panels-grid">

    <!-- Call Stack -->
    <div class="panel panel-call-stack" id="panel-callStack" data-component="callStack">
      <div class="panel-header">
        <span class="panel-label">Call Stack</span>
        <span class="panel-subtitle">Pila de llamadas</span>
      </div>
      <div class="panel-blocks" id="blocks-callStack"></div>
    </div>

    <!-- Event Loop Indicator (centro) -->
    <div class="event-loop-indicator" aria-label="Event Loop" role="img">
      <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
        <circle cx="40" cy="40" r="30" fill="none" stroke="var(--color-accent)" stroke-width="3" stroke-dasharray="8 4" class="loop-ring"/>
        <text x="40" y="36" text-anchor="middle" fill="var(--color-accent)" font-size="9" font-family="var(--font-mono)" font-weight="700">EVENT</text>
        <text x="40" y="48" text-anchor="middle" fill="var(--color-accent)" font-size="9" font-family="var(--font-mono)" font-weight="700">LOOP</text>
        <!-- Arrow head -->
        <polygon points="40,8 36,16 44,16" fill="var(--color-accent)" class="loop-arrow"/>
      </svg>
    </div>

    <!-- Web APIs -->
    <div class="panel panel-web-apis" id="panel-webAPIs" data-component="webAPIs">
      <div class="panel-header">
        <span class="panel-label">Web APIs</span>
        <span class="panel-subtitle">APIs del navegador</span>
      </div>
      <div class="panel-blocks" id="blocks-webAPIs"></div>
    </div>

    <!-- Microtask Queue -->
    <div class="panel panel-microtask-queue" id="panel-microtaskQueue" data-component="microtaskQueue">
      <div class="panel-header">
        <span class="panel-label">Microtask Queue</span>
        <span class="panel-subtitle">Cola de microtareas</span>
      </div>
      <div class="panel-blocks panel-blocks--horizontal" id="blocks-microtaskQueue"></div>
    </div>

    <!-- Callback Queue -->
    <div class="panel panel-callback-queue" id="panel-callbackQueue" data-component="callbackQueue">
      <div class="panel-header">
        <span class="panel-label">Callback Queue</span>
        <span class="panel-subtitle">Cola de callbacks</span>
      </div>
      <div class="panel-blocks panel-blocks--horizontal" id="blocks-callbackQueue"></div>
    </div>

  </div>
</div>

<script>
  import { VisualizerEngine } from '../scripts/visualizer.ts';

  const visualizer = document.getElementById('event-loop-visualizer');
  if (visualizer) {
    const engine = new VisualizerEngine();
    // Exponer el engine globalmente para que otros componentes puedan acceder
    (window as any).visualizerEngine = engine;
  }
</script>

<style>
  .visualizer {
    width: 100%;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    backdrop-filter: blur(8px);
  }

  /* Grid: 3 columnas en la fila superior, 2 columnas centradas en la inferior */
  .panels-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-4);
    align-items: start;
  }

  /* Fila 1: Call Stack | Indicator | Web APIs */
  .panel-call-stack    { grid-column: 1; grid-row: 1; }
  .event-loop-indicator { grid-column: 2; grid-row: 1 / 3; align-self: center; }
  .panel-web-apis      { grid-column: 3; grid-row: 1; }

  /* Fila 2: Microtask Queue y Callback Queue ocupan col 1 y 3 */
  .panel-microtask-queue { grid-column: 1; grid-row: 2; }
  .panel-callback-queue  { grid-column: 3; grid-row: 2; }

  /* ── Panel base ── */
  .panel {
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    overflow: hidden;
    min-width: 0; /* evita que el grid expanda el panel más allá de su columna */
    transition: border-color var(--anim-duration) var(--anim-easing),
                box-shadow var(--anim-duration) var(--anim-easing);
  }

  .panel.panel-highlighted {
    box-shadow: 0 0 0 3px currentColor, 0 0 20px currentColor;
  }

  /* ── Colores por panel ── */
  .panel-call-stack {
    border-color: var(--color-call-stack);
    color: var(--color-call-stack);
  }
  .panel-call-stack .panel-header {
    background: var(--color-call-stack-bg);
    border-bottom-color: var(--color-call-stack);
  }

  .panel-web-apis {
    border-color: var(--color-web-apis);
    color: var(--color-web-apis);
  }
  .panel-web-apis .panel-header {
    background: var(--color-web-apis-bg);
    border-bottom-color: var(--color-web-apis);
  }

  .panel-callback-queue {
    border-color: var(--color-callback-queue);
    color: var(--color-callback-queue);
  }
  .panel-callback-queue .panel-header {
    background: var(--color-callback-queue-bg);
    border-bottom-color: var(--color-callback-queue);
  }

  .panel-microtask-queue {
    border-color: var(--color-microtask-queue);
    color: var(--color-microtask-queue);
  }
  .panel-microtask-queue .panel-header {
    background: var(--color-microtask-queue-bg);
    border-bottom-color: var(--color-microtask-queue);
  }

  /* ── Panel header ── */
  .panel-header {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid;
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: inherit;
  }

  .panel-subtitle {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: 400;
  }

  /* ── Área de bloques ── */
  .panel-blocks {
    min-height: 120px;
    padding: var(--space-3);
    display: flex;
    flex-direction: column-reverse; /* Call Stack: los nuevos van arriba */
    gap: var(--space-2);
    align-items: stretch;
    /* Contener desbordamiento de bloques */
    overflow: hidden;
    min-width: 0;
  }

  /* Queues: bloques en fila horizontal */
  .panel-blocks--horizontal {
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    min-height: 64px;
    gap: var(--space-2);
  }

  /* ── Event Loop Indicator ── */
  .event-loop-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
  }

  .loop-ring {
    animation: spin 4s linear infinite;
    transform-origin: 40px 40px;
  }

  .loop-arrow {
    animation: spin 4s linear infinite;
    transform-origin: 40px 40px;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
</style>
