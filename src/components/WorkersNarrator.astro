---
// WorkersNarrator.astro — muestra el texto explicativo sincronizado con la animación de Web Workers
---

<div
  id="workers-narrator"
  class="narrator"
  role="status"
  aria-live="polite"
  aria-atomic="true"
>
  Selecciona un ejemplo y pulsa Ejecutar para comenzar.
</div>

<script>
  (function () {
    const narrator = document.getElementById('workers-narrator') as HTMLElement;
    if (!narrator) return;

    document.addEventListener('workers:step', (e: Event) => {
      const detail = (e as CustomEvent<{ text: string }>).detail;
      if (detail?.text) {
        narrator.textContent = detail.text;
      }
    });
  })();
</script>

<style>
  .narrator {
    padding: var(--space-4) var(--space-6);
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text);
    min-height: 4.5rem;
    display: flex;
    align-items: center;
  }
</style>
